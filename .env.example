# En dev, utiliser le proxy Vite (évite les erreurs CORS) :
VITE_GLPI_API_URL=/api/glpi/v2.3
VITE_GLPI_TOKEN_URL=/api/glpi/token
# Cible du proxy Vite (optionnel, défaut : http://glpi.localhost)
# VITE_GLPI_PROXY_TARGET=http://glpi.localhost
# En production, utiliser les URLs directes :
# VITE_GLPI_API_URL=http://glpi.localhost/api.php/v2.3
# VITE_GLPI_TOKEN_URL=http://glpi.localhost/api.php/token
VITE_GLPI_CLIENT_ID=your_client_id
VITE_GLPI_CLIENT_SECRET=your_client_secret
VITE_GLPI_USERNAME=your_glpi_username
VITE_GLPI_PASSWORD=your_glpi_password
# Le client OAuth doit autoriser les scopes "api" et "user" (requis pour /User/Me)
VITE_ADMIN_CODE=123456789
VITE_GLPI_IMPORT_USER_PASSWORD=Import123!
# API Legacy (liaison actifs ↔ tickets via Item_Ticket)
VITE_GLPI_LEGACY_API_URL=/api/glpi-legacy
VITE_GLPI_APP_TOKEN=your_app_token
VITE_GLPI_USER_TOKEN=your_user_token
